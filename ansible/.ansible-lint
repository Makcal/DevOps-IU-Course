# ansible-lint configuration
# Skip style-only rules that are present in existing codebase
warn_list:
  - yaml[truthy]
  - fqcn[action-core]
  - fqcn[action]
  - var-naming[no-role-prefix]
  - key-order[task]
  - name[casing]

skip_list:
  - yaml[truthy]
  - fqcn[action-core]
  - fqcn[action]
  - var-naming[no-role-prefix]
  - key-order[task]
  - name[casing]
  - ignore-errors
